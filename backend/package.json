{
  "name": "iraq-catalog-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"import { mkdirSync, copyFileSync } from 'node:fs'; mkdirSync('dist/shared/db', { recursive: true }); copyFileSync('shared/db/schema.sql', 'dist/shared/db/schema.sql');\"",
    "dev:api": "tsx watch api/server.ts",
    "dev:sqlite-api": "CATALOG_ALLOW_INSECURE_DEFAULTS=true CATALOG_SKIP_SCRAPED_IMPORT=true CATALOG_SKIP_STARTUP_REINDEX=true SNAPSHOT_STORAGE_DRIVER=local SNAPSHOT_LOCAL_STORAGE_DIR=.catalog-storage/sqlite tsx watch api/server.ts",
    "dev:worker": "tsx watch worker/run-worker.ts",
    "dev:memory-api": "CATALOG_ALLOW_INSECURE_DEFAULTS=true tsx worker/run-memory-catalog-api.ts",
    "dev:miswag-api": "CATALOG_ALLOW_INSECURE_DEFAULTS=true SNAPSHOT_STORAGE_DRIVER=local SNAPSHOT_LOCAL_STORAGE_DIR=.catalog-storage/miswag tsx worker/run-memory-catalog-api.ts --store-id manual_miswag --concurrency 1",
    "sync:current": "tsx worker/run-sync-current-sites.ts",
    "pull:products": "tsx worker/run-product-pull-cycle.ts",
    "audit:data": "CATALOG_ALLOW_INSECURE_DEFAULTS=true tsx worker/run-data-audit.ts",
    "backfill:canonical-ids": "node dist/worker/run-backfill-canonical-ids.js",
    "reindex:search": "tsx worker/run-rebuild-search-index.ts",
    "refresh:all": "tsx worker/run-bulk-refresh.ts",
    "export:full": "tsx worker/run-full-catalog-export.ts",
    "export:registry": "tsx worker/run-registry-export.ts",
    "export:site": "tsx worker/run-site-export.ts",
    "refresh:retry-report": "tsx worker/run-report-retry.ts",
    "start:api": "node dist/api/start.js",
    "start:worker": "node dist/worker/run-worker.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.883.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "bullmq": "^5.58.5",
    "cheerio": "^1.1.2",
    "dotenv": "^16.6.1",
    "fast-xml-parser": "^5.3.0",
    "fastify": "^5.6.0",
    "ioredis": "^5.8.0",
    "pg": "^8.16.3",
    "playwright": "^1.55.0",
    "typesense": "^2.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}

{
  "name": "iraq-catalog-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev:api": "tsx watch api/server.ts",
    "dev:worker": "tsx watch worker/run-worker.ts",
    "dev:memory-api": "CATALOG_ALLOW_INSECURE_DEFAULTS=true tsx worker/run-memory-catalog-api.ts",
    "dev:miswag-api": "CATALOG_ALLOW_INSECURE_DEFAULTS=true SNAPSHOT_STORAGE_DRIVER=local SNAPSHOT_LOCAL_STORAGE_DIR=.catalog-storage/miswag tsx worker/run-memory-catalog-api.ts --store-id manual_miswag --concurrency 1",
    "refresh:all": "tsx worker/run-bulk-refresh.ts",
    "export:full": "tsx worker/run-full-catalog-export.ts",
    "export:registry": "tsx worker/run-registry-export.ts",
    "export:site": "tsx worker/run-site-export.ts",
    "refresh:retry-report": "tsx worker/run-report-retry.ts",
    "start:api": "node dist/api/server.js",
    "start:worker": "node dist/worker/run-worker.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.883.0",
    "bullmq": "^5.58.5",
    "cheerio": "^1.1.2",
    "dotenv": "^16.6.1",
    "fast-xml-parser": "^5.3.0",
    "fastify": "^5.6.0",
    "ioredis": "^5.8.0",
    "pg": "^8.16.3",
    "playwright": "^1.55.0",
    "typesense": "^2.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}

PORT=4400
CATALOG_BIND_HOST=127.0.0.1
CATALOG_TRUST_PROXY=true
CATALOG_REPO_ROOT=/app
CATALOG_ALLOWED_ORIGINS=https://hayeer.com,https://www.hayeer.com,https://h-db.site,https://www.h-db.site,https://cf.h-db.site
DATABASE_URL=postgres://catalog:catalog@postgres:5432/catalog
REDIS_URL=redis://redis:6379
TYPESENSE_URL=http://typesense:8108
TYPESENSE_API_KEY=__SET_STRONG_TYPESENSE_API_KEY__
STORAGE_BUCKET=catalog-snapshots
STORAGE_ENDPOINT=http://minio:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=__SET_MINIO_ACCESS_KEY__
STORAGE_SECRET_KEY=__SET_MINIO_SECRET_KEY__
STORAGE_FORCE_PATH_STYLE=true
SNAPSHOT_STORAGE_DRIVER=s3
SNAPSHOT_LOCAL_STORAGE_DIR=
SNAPSHOT_ENCRYPTION_KEY_BASE64=__SET_32_BYTE_BASE64_KEY__
INTERNAL_SERVICE_TOKENS=reader:__SET_READ_TOKEN__:catalog.read,operator:__SET_OPERATOR_TOKEN__:catalog.queue|catalog.session|catalog.feed
TOKEN_PEPPER=__SET_TOKEN_PEPPER__
INTERNAL_REQUIRE_REQUEST_SIGNATURE=true
INTERNAL_REQUEST_MAX_SKEW_SECONDS=300
ADMIN_LOGIN_SECRET=__SET_ADMIN_LOGIN_SECRET__
ADMIN_SESSION_SECRET=__SET_ADMIN_SESSION_SECRET__
ADMIN_SESSION_TTL_HOURS=12
CATALOG_ALLOW_INSECURE_DEFAULTS=false
PROBE_USER_AGENT=IraqCatalogBot/0.1 (+internal)
QUEUE_PREFIX=iraq_catalog
